<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Arnold & Loïc — Bureau</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">
<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
  import {
    getFirestore, collection, onSnapshot, doc, updateDoc, query, orderBy, addDoc, serverTimestamp
  } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js";

  const firebaseConfig = {
    apiKey: "AIzaSyC3nA4EeIBUj9juovNCMWGvCepCwX-J2nI",
    authDomain: "irabaruta-16f22.firebaseapp.com",
    projectId: "irabaruta-16f22",
    storageBucket: "irabaruta-16f22.firebasestorage.app",
    messagingSenderId: "263938610161",
    appId: "1:263938610161:web:5f64df392b5f3d565e2a50"
  };

  const app = initializeApp(firebaseConfig);
  const db = getFirestore(app);

  const IMGBB_API_KEY = "8b1ab08e1a05b3f81bd13db1812db462";

  async function uploadToImgBB(file){
    const formData = new FormData();
    formData.append("image", file);
    const res = await fetch(`https://api.imgbb.com/1/upload?key=${IMGBB_API_KEY}`, {
      method: "POST",
      body: formData
    });
    const json = await res.json();
    if(!json.success) throw new Error("Échec upload ImgBB");
    return json.data.url;
  }

  window.__submitGalerie = async function(titre, categorie, file){
    const statusEl = document.getElementById('galerieStatus');
    try{
      statusEl.textContent = "Envoi en cours...";
      statusEl.className = "form-status pending";
      const url = await uploadToImgBB(file);
      await addDoc(collection(db, "galerie"), {
        titre, categorie, url, createdAt: serverTimestamp()
      });
      statusEl.textContent = "✓ Œuvre ajoutée à la galerie.";
      statusEl.className = "form-status success";
      document.getElementById('galerieForm').reset();
    }catch(err){
      console.error(err);
      statusEl.textContent = "Erreur d'envoi — réessaie.";
      statusEl.className = "form-status error";
    }
  };

  const TYPE_LABELS = {
    evenement: "Événement",
    business: "Business",
    portrait: "Portrait",
    autre: "Sur mesure"
  };
  const DELAI_LABELS = { normal: "Normal (48-72h)", urgent: "Urgent (24h)" };
  const STATUT_LABELS = {
    nouveau: "Nouveau",
    en_cours: "En cours",
    revision: "Révision",
    livre: "Livré"
  };
  const STATUT_ORDER = ["nouveau", "en_cours", "revision", "livre"];

  function formatDate(ts){
    if(!ts || !ts.toDate) return "à l'instant";
    return ts.toDate().toLocaleString('fr-FR', { day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' });
  }

  function whatsappLink(contact){
    const clean = contact.replace(/[^0-9+]/g, '');
    return `https://wa.me/${clean.replace('+','')}`;
  }

  function render(snap){
    const list = document.getElementById('list');
    const emptyState = document.getElementById('emptyState');
    const countBadge = document.getElementById('countBadge');

    if(snap.empty){
      list.innerHTML = '';
      emptyState.style.display = 'block';
      countBadge.textContent = '0';
      return;
    }
    emptyState.style.display = 'none';

    const filter = document.getElementById('filterSelect').value;
    let docs = snap.docs;
    if(filter !== 'toutes'){
      docs = docs.filter(d => (d.data().statut || 'nouveau') === filter);
    }
    countBadge.textContent = docs.length;

    list.innerHTML = docs.map(d => {
      const c = d.data();
      const id = d.id;
      const statut = c.statut || 'nouveau';
      const photos = (c.photos || []).map(url =>
        `<img src="${url}" onclick="window.open('${url}','_blank')">`
      ).join('');

      const statutButtons = STATUT_ORDER.map(s =>
        `<button class="statut-btn ${s === statut ? 'active' : ''}" data-id="${id}" data-statut="${s}">${STATUT_LABELS[s]}</button>`
      ).join('');

      return `
        <div class="card">
          <div class="card-top">
            <div>
              <div class="card-name">${c.nom || 'Sans nom'}</div>
              <div class="card-meta">${TYPE_LABELS[c.type] || c.type} · ${DELAI_LABELS[c.delai] || ''}</div>
            </div>
            <span class="badge-statut statut-${statut}">${STATUT_LABELS[statut]}</span>
          </div>

          <p class="card-desc">${c.description || ''}</p>

          ${photos ? `<div class="photo-row">${photos}</div>` : ''}

          <div class="card-footer">
            <span class="card-date">${formatDate(c.createdAt)}</span>
            <a class="wa-link" href="${whatsappLink(c.contact || '')}" target="_blank">WhatsApp →</a>
          </div>

          <div class="statut-row">${statutButtons}</div>
        </div>
      `;
    }).join('');

    document.querySelectorAll('.statut-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.id;
        const statut = btn.dataset.statut;
        try{
          await updateDoc(doc(db, "commandes", id), { statut });
        }catch(err){
          console.error(err);
          alert("Erreur de mise à jour du statut.");
        }
      });
    });
  }

  // ⚠️ Change ce code si tu veux — c'est le mot de passe d'accès au bureau
  const SECRET_CODE = "LOIC2026";

  function unlockDashboard(){
    document.getElementById('lockScreen').style.display = 'none';
    document.getElementById('dashboardContent').style.display = 'block';
    initDashboard();
  }

  function checkCode(){
    const val = document.getElementById('lockInput').value.trim();
    if(val === SECRET_CODE){
      sessionStorage.setItem('arnoldloic_unlocked', '1');
      unlockDashboard();
    }else{
      document.getElementById('lockError').textContent = "Code incorrect.";
    }
  }

  window.addEventListener('DOMContentLoaded', () => {
    if(sessionStorage.getItem('arnoldloic_unlocked') === '1'){
      unlockDashboard();
    }
    document.getElementById('lockBtn').addEventListener('click', checkCode);
    document.getElementById('lockInput').addEventListener('keydown', e => {
      if(e.key === 'Enter') checkCode();
    });

    document.getElementById('galSubmitBtn').addEventListener('click', () => {
      const titre = document.getElementById('galTitre').value.trim();
      const categorie = document.getElementById('galCategorie').value;
      const fileInput = document.getElementById('galPhoto');
      const file = fileInput.files[0];
      if(!titre || !file){
        document.getElementById('galerieStatus').textContent = "Remplis le titre et choisis une image.";
        document.getElementById('galerieStatus').className = "form-status error";
        return;
      }
      window.__submitGalerie(titre, categorie, file);
    });
  });

  function initDashboard(){
    const q = query(collection(db, "commandes"), orderBy("createdAt", "desc"));
    let lastSnap = null;
    onSnapshot(q, snap => {
      lastSnap = snap;
      render(snap);
    }, err => {
      console.error(err);
      document.getElementById('emptyState').textContent = "Erreur de connexion à Firestore.";
      document.getElementById('emptyState').style.display = 'block';
    });

    document.getElementById('filterSelect').addEventListener('change', () => {
      if(lastSnap) render(lastSnap);
    });
  }
</script>
<style>
  :root{
    --night: #14142B; --night-2: #1E1E42;
    --sunset: #E8622C; --gold: #F2A65A; --teal: #1F7A6C;
    --cream: #F5EFE0; --line: rgba(245,239,224,0.14);
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  html,body{
    background: var(--night); color: var(--cream);
    font-family: 'Space Grotesk', sans-serif; min-height:100vh;
  }
  body{
    background:
      radial-gradient(ellipse 900px 500px at 50% -10%, rgba(232,98,44,0.2), transparent 60%),
      linear-gradient(180deg, var(--night) 0%, var(--night-2) 100%);
  }
  header{
    padding: 22px 20px 16px; border-bottom: 1px solid var(--line);
    display:flex; align-items:center; justify-content:space-between;
  }
  .header-title{
    font-family:'Anton', sans-serif; font-weight:400; font-size:22px;
    text-transform:uppercase; letter-spacing:0.02em;
  }
  .header-sub{ font-size:11.5px; color:rgba(245,239,224,0.5); margin-top:2px; }
  .count-pill{
    background: linear-gradient(135deg, var(--sunset), var(--gold));
    color: var(--night); font-weight:700; font-size:13px;
    padding: 6px 12px; border-radius: 20px; min-width:28px; text-align:center;
  }

  main{ max-width: 560px; margin:0 auto; padding: 18px 16px 60px; }

  .add-gallery{
    border: 1px solid var(--line); border-radius: 16px;
    padding: 16px; margin-bottom: 22px;
    background: rgba(245,239,224,0.02);
  }
  .add-gallery-title{
    font-size: 12.5px; font-weight:700; text-transform:uppercase;
    letter-spacing: 0.08em; color: var(--gold); margin-bottom: 12px;
  }
  .add-gallery .field{ margin-bottom: 10px; }
  .add-gallery label{
    display:block; font-size: 12px; font-weight:700;
    margin-bottom: 5px; color: rgba(245,239,224,0.75);
  }
  .add-gallery input[type=text], .add-gallery select{
    width:100%; padding: 10px 12px; border-radius: 9px;
    border: 1.5px solid var(--line); background: rgba(245,239,224,0.04);
    color: var(--cream); font-family: inherit; font-size: 13.5px;
  }
  .add-gallery input[type=file]{
    width:100%; font-size: 12.5px; color: rgba(245,239,224,0.6);
  }
  .add-gallery button{
    width:100%; border:none; padding: 12px; border-radius: 10px;
    font-family: inherit; font-weight:700; font-size: 13.5px;
    background: linear-gradient(135deg, var(--sunset), var(--gold));
    color: var(--night); cursor:pointer; margin-top: 4px;
  }
  .form-status{ margin-top: 10px; font-size: 12.5px; text-align:center; }
  .form-status.pending{ color: var(--gold); }
  .form-status.success{ color: var(--teal); font-weight:700; }
  .form-status.error{ color: var(--sunset); font-weight:700; }

  .filter-bar{ margin-bottom: 16px; }
  select#filterSelect{
    width:100%; padding: 11px 14px; border-radius: 10px;
    border: 1.5px solid var(--line); background: rgba(245,239,224,0.04);
    color: var(--cream); font-family: inherit; font-size: 13.5px;
  }

  .lock-screen{
    position:fixed; inset:0; z-index:100;
    background: linear-gradient(180deg, var(--night) 0%, var(--night-2) 100%);
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    padding: 30px;
  }
  .lock-title{
    font-family:'Anton', sans-serif; font-weight:400; font-size:26px;
    text-transform:uppercase; margin-bottom: 6px; text-align:center;
  }
  .lock-sub{
    font-size: 13px; color: rgba(245,239,224,0.5);
    margin-bottom: 24px; text-align:center;
  }
  .lock-input{
    width:100%; max-width: 280px; padding: 14px 16px;
    border-radius: 12px; border: 1.5px solid var(--line);
    background: rgba(245,239,224,0.05); color: var(--cream);
    font-family: inherit; font-size: 16px; text-align:center;
    letter-spacing: 0.1em; margin-bottom: 14px;
  }
  .lock-btn{
    width:100%; max-width: 280px; border:none; padding: 14px;
    border-radius: 12px; font-family: inherit; font-weight:700; font-size: 14.5px;
    background: linear-gradient(135deg, var(--sunset), var(--gold));
    color: var(--night); cursor:pointer;
  }
  .lock-error{
    margin-top: 12px; font-size: 12.5px; color: var(--sunset); min-height: 16px;
  }
  #dashboardContent{ display:none; }

  #emptyState{
    display:none; text-align:center; padding: 60px 20px;
    color: rgba(245,239,224,0.4); font-size: 14px;
  }

  .card{
    border: 1px solid var(--line); border-radius: 16px;
    padding: 16px; margin-bottom: 14px;
    background: rgba(245,239,224,0.02);
  }
  .card-top{ display:flex; justify-content:space-between; align-items:flex-start; gap:10px; }
  .card-name{ font-weight:700; font-size: 15.5px; }
  .card-meta{ font-size: 12px; color: rgba(245,239,224,0.5); margin-top:2px; }

  .badge-statut{
    font-size: 10.5px; font-weight:700; text-transform:uppercase;
    padding: 5px 10px; border-radius: 20px; white-space:nowrap;
  }
  .statut-nouveau{ background: rgba(232,98,44,0.2); color: var(--gold); }
  .statut-en_cours{ background: rgba(242,166,90,0.2); color: var(--gold); }
  .statut-revision{ background: rgba(31,122,108,0.2); color: var(--teal); }
  .statut-livre{ background: rgba(31,122,108,0.35); color: var(--teal); }

  .card-desc{
    font-size: 13.5px; color: rgba(245,239,224,0.8);
    margin-top: 10px; line-height:1.4;
  }

  .photo-row{
    display:flex; gap:8px; margin-top:12px; overflow-x:auto; padding-bottom:2px;
  }
  .photo-row img{
    width:64px; height:64px; object-fit:cover; border-radius:10px;
    border: 1px solid var(--line); flex-shrink:0; cursor:pointer;
  }

  .card-footer{
    display:flex; justify-content:space-between; align-items:center;
    margin-top: 12px; font-size: 12px;
  }
  .card-date{ color: rgba(245,239,224,0.4); }
  .wa-link{
    color: var(--teal); font-weight:700; text-decoration:none;
  }

  .statut-row{
    display:flex; gap:6px; margin-top: 12px; flex-wrap:wrap;
  }
  .statut-btn{
    flex:1; min-width: 70px;
    padding: 9px 6px; border-radius: 9px;
    border: 1.5px solid var(--line); background: transparent;
    color: rgba(245,239,224,0.6); font-family: inherit;
    font-size: 11.5px; font-weight:700; cursor:pointer;
  }
  .statut-btn.active{
    border-color: var(--sunset);
    background: rgba(232,98,44,0.15);
    color: var(--cream);
  }
</style>
</head>
<body>

<div class="lock-screen" id="lockScreen">
  <div class="lock-title">Bureau</div>
  <div class="lock-sub">Arnold &amp; Loïc Studio — accès privé</div>
  <input type="password" class="lock-input" id="lockInput" placeholder="Code secret" inputmode="text">
  <button class="lock-btn" id="lockBtn">Entrer</button>
  <div class="lock-error" id="lockError"></div>
</div>

<div id="dashboardContent">
<header>
  <div>
    <div class="header-title">Bureau</div>
    <div class="header-sub">Arnold &amp; Loïc Studio</div>
  </div>
  <span class="count-pill" id="countBadge">0</span>
</header>

<main>
  <div class="add-gallery">
    <div class="add-gallery-title">Ajouter à la galerie</div>
    <form id="galerieForm" onsubmit="return false;">
      <div class="field">
        <label>Titre de l'œuvre</label>
        <input type="text" id="galTitre" placeholder="Ex: Coucher sur le lac" required>
      </div>
      <div class="field">
        <label>Catégorie</label>
        <select id="galCategorie" required>
          <option value="evenement">Événements</option>
          <option value="business">Business</option>
          <option value="portrait">Portraits</option>
          <option value="autre">Sur mesure</option>
        </select>
      </div>
      <div class="field">
        <label>Image</label>
        <input type="file" id="galPhoto" accept="image/*" required>
      </div>
      <button id="galSubmitBtn" type="button">Publier dans la galerie</button>
      <div class="form-status" id="galerieStatus"></div>
    </form>
  </div>

  <div class="filter-bar">
    <select id="filterSelect">
      <option value="toutes">Toutes les commandes</option>
      <option value="nouveau">Nouveau</option>
      <option value="en_cours">En cours</option>
      <option value="revision">Révision</option>
      <option value="livre">Livré</option>
    </select>
  </div>

  <div id="emptyState">Aucune commande pour le moment.</div>
  <div id="list"></div>
</main>
</div>

</body>
</html>
